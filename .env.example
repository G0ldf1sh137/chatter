POSTGRES_DB=chatter
POSTGRES_USER=chatter
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# From Google Cloud Console (APIs & Services > Credentials). See README for setup steps.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Leave EMAIL_HOST unset in dev - verification emails print to the runserver
# log instead of sending. Set these for a real deployment.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=noreply@chatter.local
