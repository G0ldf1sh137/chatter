POSTGRES_DB=chatter
POSTGRES_USER=chatter
POSTGRES_PASSWORD=changeme
POSTGRES_HOST=db
POSTGRES_PORT=5432

# Alternative to the POSTGRES_* vars above - a single connection string, as
# provided by Neon/Render/most managed Postgres hosts. Takes priority over
# POSTGRES_* if both are set. See README's Deploying section.
# DATABASE_URL=postgres://user:password@host/dbname?sslmode=require

SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# From Google Cloud Console (APIs & Services > Credentials). See README for setup steps.
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Leave EMAIL_HOST unset in dev - verification emails print to the runserver
# log instead of sending. Set these for a real deployment.
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=1
DEFAULT_FROM_EMAIL=noreply@chatter.local

# Optional - switches avatar/media storage from local disk to S3-compatible
# storage (needed on hosts with ephemeral disk, like Render's free tier,
# where local uploads are wiped on every redeploy/restart). Leave unset to
# keep local disk storage. Works with AWS S3 directly, or any S3-compatible
# host (e.g. Cloudflare R2, Backblaze B2) via AWS_S3_ENDPOINT_URL.
AWS_STORAGE_BUCKET_NAME=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION_NAME=auto
AWS_S3_ENDPOINT_URL=
